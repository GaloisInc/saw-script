// This test mirrors testGoodImport1 but with "import submodule ... as ..."
//                                                                  --

import "D.cry";

// access vars fully qualified:
print {{D2::d2}};
print {{D2::D3::d3}};

// submodule D2 should be in scope to `import submodule`
import submodule D2 as MYD2;

// can now access ... w/ "MYD2" prefix:
print {{MYD2::d2}};

// and can accesss submodule D3 via MYD2:
print {{MYD2::D3::d3}};
//   FIXME: the above should work!

///////////////////////////////////////
// Now test multiple submodule nesting:

// submodule D3 should be in scope NOW:
import submodule MYD2::D3 as MYD3;

print {{MYD3::d3}};

print "done";
