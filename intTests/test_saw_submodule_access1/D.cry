module D where
import B
import C

d00 = 2000 + b + c  // 2000 + 12 + 102 = 2114
                    // checking normal imports from B & C work

type DTySy = [32]

submodule D2 where
  d2 = d00 + 10000  // 12114

  type D2TySy = [32]

  submodule D3 where
    d3 = d00 + d2 + 1  // 14229

    type D3TySy = [32]

// Ensuring we can reference submodules & multiply-nested submodules:
//  - type synonyms and values
d01 : D2::D3::D3TySy
d01 = 5 + D2::d2   // D2 is not referencable till now!
    + D2::D3::d3   

