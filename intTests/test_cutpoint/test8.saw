m <- llvm_load_module "test8.bc";

let ptr_to_fresh n ty = do {
  p <- llvm_alloc ty;
  x <- llvm_fresh_var n ty;
  llvm_points_to p (llvm_term x);
  return (p, x);
};

let count_forever_spec = do {
  c <- llvm_fresh_var "c" (llvm_int 64);
  llvm_execute_func [];
  llvm_return (llvm_term {{ 71 : [64] }});
};

let inv_spec = do {
  (p, c) <- ptr_to_fresh "c" (llvm_int 64);
  llvm_precond {{ True }};
  llvm_execute_func [p];
  llvm_return (llvm_term {{ 71 : [64] }});
};

inv <- llvm_unsafe_assume_spec m "__cutpoint__inv#count_forever" inv_spec;
llvm_verify m "__cutpoint__inv#count_forever" [inv] true inv_spec z3;
llvm_verify m "count_forever" [inv] true count_forever_spec z3;
