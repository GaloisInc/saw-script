bc <- llvm_load_module "main.bc";
bc_foo <- llvm_load_module "foo.bc";
bc_bar <- llvm_load_module "bar.bc";

let i32 = llvm_int 32;

enable_experimental;

allbc <- llvm_combine_modules bc [bc_foo, bc_bar];

llvm_verify allbc "baz" [] false
do {
  llvm_execute_func [llvm_term {{4 : [32]}}];
  llvm_return (llvm_term {{ 55 : [32] }});
  }
  z3;
