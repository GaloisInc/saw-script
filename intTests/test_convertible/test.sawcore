               a = addNat a a;a = addNat a a;a = addNat a a;
               a = addNat a a;a = addNat a a;a = addNat a a;
               a = addNat a a;a = addNat a a;a = addNat a a;
               a = addNat a a;a = addNat a a;a = addNat a a;
               a = addNat a a;a = addNat a a;a = addNat a a;
               a = addNat a a;a = addNat a a;a = addNat a a;
             } in a;