enable_experimental;
load_sawcore_from_file "test.sawcore";

let go s = (beta_reduce_term (unfold_term ["test"] (parse_core s)));

let t1 = go "\\(a : Nat) -> test a";
let t2 = go "\\(b : Nat) -> test b";
let t3 = go "\\(a : Nat) -> test (addNat a a)";

let assert b msg = if b then return () else fail msg;


// without caching, these convertibility checks take more than
// 1 second
// with caching they take <1ms

(elapsed1, b1) <- with_time (is_convertible t1 t2);
assert (eval_bool {{ `(elapsed1) < 5 }}) "is_convertible took too long";
assert b1 "unexpected non-convertible";

(elapsed2, b2) <- with_time (is_convertible t1 t3);
assert (eval_bool {{ `(elapsed2) < 5 }}) "is_convertible took too long";
assert (eval_bool {{ ~ b2 }}) "unexpected convertible";

print "Success";