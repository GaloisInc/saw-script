import "../../examples/ecdsa/cryptol-spec/ecc.cry";
let t1 = unfold_term ["ecdsa_public_verify_imp"] {{ ecdsa_public_verify_imp }};
let t2 = parse_core (show_term t1);

assert_tyeq t1 t2;
print (show (type t2));
