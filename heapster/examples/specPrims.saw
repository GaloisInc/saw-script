/* Helper SAW script for using specification primitives in Cryptol */

import "SpecPrims.cry";

set_monadification "exists" "sawcore:SpecM.existsS" true;
set_monadification "forall" "sawcore:SpecM.forallS" true;
set_monadification "asserting" "sawcore:SpecM.asserting" true;
set_monadification "assuming" "sawcore:SpecM.assuming" true;
set_monadification "invariantHint" "sawcore:SpecM.invariantHint" true;
