cryptol_definition myEnum_eq :: "{'a,'b} ((Eq 'a,fin 'b) =?> ((('a,'b) MyEnum) \<Rightarrow> ((('a,'b) MyEnum) \<Rightarrow> Bit)))" where
"myEnum_eq x y \<equiv> case x of
    MyCtr2 i b a c \<Rightarrow> (case y of
      MyCtr2 i1 b1 a1 c1 \<Rightarrow> ((i ==`{Integer} i1) \<and> ((b ==`{['b]} b1) \<and> ((a ==`{'a} a1) \<and> (c ==`{Bit} c1))))
    | _ \<Rightarrow> (False))
  | MyNone \<Rightarrow> (case y of
      MyNone \<Rightarrow> (True)
    | _ \<Rightarrow> (False))
  | MySome a \<Rightarrow> (case y of
      MySome a1 \<Rightarrow> (a ==`{'a} a1)
    | _ \<Rightarrow> (False))"

cryptol_definition myEnum_eq_valid :: "{'a,'b,'c} ((Eq 'a,fin 'b,'b = 'c) =?> ((('a,'b) MyEnum) \<Rightarrow> ((('a,'c) MyEnum) \<Rightarrow> Bit)))" where
"myEnum_eq_valid x y \<equiv> (myEnum_eq`{'a,'b} x y) ==`{Bit} (x ==`{('a,'b) MyEnum} y)"

cryptol_definition opt_valid :: "{'a,'b} ((fin 'a,'a = 'b) =?> (((['a]) Option) \<Rightarrow> (((['b]) Option) \<Rightarrow> Bit)))" where
"opt_valid x y \<equiv> case x of
    None \<Rightarrow> (case y of
      None \<Rightarrow> (x ==`{(['a]) Option} y)
    | Some b \<Rightarrow> (complement`{Bit} (x ==`{(['a]) Option} y)))
  | Some a \<Rightarrow> (case y of
      None \<Rightarrow> (complement`{Bit} (x ==`{(['a]) Option} y))
    | Some b \<Rightarrow> ((a ==`{['b]} b) ==`{Bit} (x ==`{(['a]) Option} y)))"

