enable_experimental;

// Obligation-shape litmus: Cryptol ecAt on a finite sequence must expose the
// bounds/index evidence consumed by the underlying vector access.
let probe =
  parse_core "ecAt (TCNum 4) Bool Integer PIntegralInteger 0b1010 (natToInt 2)";

write_lean_term "CryptolEcAtBoundsProbe" [] [] "emitted.lean" probe;
