enable_experimental;

load_sawcore_from_file "ExternalPrim.sawcore";

// Obligation-shape litmus: primitives declared in loaded SAWCore modules need
// a checked Lean realization contract, not a bare trusted name.
let probe = parse_core_mod "ExternalPrim" "observed";

write_lean_term "LoadedPrimitiveDeclProbe" [] [] "emitted.lean" probe;
