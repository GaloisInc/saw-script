enable_experimental;

// Obligation-shape litmus: fully-applied unsafeAssert over a provable but
// non-definitional Nat equality must expose the literal equality obligation.
let probe = parse_core "unsafeAssert Nat (addNat 1 1) 2";

write_lean_term "UnsafeAssertNatEqProbe" [] [] "emitted.lean" probe;
