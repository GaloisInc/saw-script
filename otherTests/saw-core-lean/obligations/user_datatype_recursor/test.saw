enable_experimental;

load_sawcore_from_file "Color.sawcore";

// Obligation-shape litmus: user datatypes require a checked Lean realization
// for the type, constructors, and recursor before residual values are sound.
let probe =
  parse_core_mod "Color"
    "\\(c : Color) -> Color#rec (\\(_ : Color) -> Bool) True False c";

write_lean_term "UserDatatypeObligationProbe" [] [] "emitted.lean" probe;
