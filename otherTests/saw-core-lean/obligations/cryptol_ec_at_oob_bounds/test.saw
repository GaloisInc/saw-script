enable_experimental;

// Obligation-shape litmus: out-of-bounds finite Cryptol ecAt must still emit
// the exact vector bounds obligation. The obligation is intentionally false
// for this closed term; proof discharge is a separate phase.
let probe =
  parse_core "ecAt (TCNum 4) Bool Integer PIntegralInteger 0b1010 (natToInt 4)";

write_lean_term "CryptolEcAtOutOfBoundsProbe" [] [] "emitted.lean" probe;
