enable_experimental;

load_sawcore_from_file "Injected.lean.sawcore";

// Obligation-shape litmus: injected Lean code is a SAWCore module
// declaration. The current public term-emission path does not emit module
// injected declarations, so this pins the gap as a corpus case.
let probe = parse_core_mod "Injected" "observed";

write_lean_term "InjectedLeanCodeProbe" [] [] "emitted.lean" probe;
