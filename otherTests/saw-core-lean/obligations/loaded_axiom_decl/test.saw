enable_experimental;

load_sawcore_from_file "ExternalAxiom.sawcore";

// Obligation-shape litmus: axioms declared in loaded SAWCore modules need a
// checked Lean theorem realization or generated proof obligation.
let probe = parse_core_mod "ExternalAxiom" "observed";

write_lean_term "LoadedAxiomDeclProbe" [] [] "emitted.lean" probe;
