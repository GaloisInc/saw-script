enable_experimental;

// `fix_unfold` is an axiom in SAW Prelude expressing the unfolding
// equation for `Prelude.fix`. The proof-carrying fix term itself is
// now emitted with an explicit obligation, but residual `fix_unfold`
// remains rejected as a primitive proof principle rather than being
// trusted directly.
let probe = parse_core "fix_unfold Bool (\\(b : Bool) -> b)";

write_lean_term "probe" [] [] "-" probe;
