// Polynomial literals specialize through raw-position Prelude.error.
// The Lean backend emits an explicit unreachable-branch proof obligation
// rather than manufacturing a raw index/proof/type/function value.
let t = {{ <| x^^6 + x^^4 + x^^2 + x^^1 + 1 |> }};
write_lean_term "TestLit_Poly1" [] [] "polynomial_literal.t1.lean" t;
