// Differential conformance checks for small core Prelude control helpers.
//
// `id` is auto-emitted from the SAWCore Prelude, while `sawLet` is routed to a
// checked Lean facade because it needs the Phase-beta value-domain convention.

let core_id_conformance = parse_core "equalNat (id Nat 5) 5";
prove_print w4 core_id_conformance;
write_lean_term
  "CoreIdConformance" [] []
  "test_conformance_core.id.result.lean"
  core_id_conformance;

let core_sawlet_conformance = parse_core "sawLet Nat Bool 3 (\\(x : Nat) -> equalNat x 3)";
prove_print w4 core_sawlet_conformance;
write_lean_term
  "CoreSawLetConformance" [] []
  "test_conformance_core.sawlet.result.lean"
  core_sawlet_conformance;
