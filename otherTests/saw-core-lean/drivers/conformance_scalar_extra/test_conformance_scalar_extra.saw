// Additional differential conformance checks for defined scalar primitives.
//
// The older `conformance_scalar` fixture intentionally remains focused on the
// division/precondition surface it already exposes. This fixture adds defined
// Nat, Int, IntMod, and Rational operations without changing that failing
// regression probe.

// `leNat 4 4` is deliberately absent: the current SAW `w4` prover path
// panics while evaluating that closed SAWCore term. Track that as a conformance
// backlog item rather than hiding it in this passing defined-operation fixture.
let nat_scalar_extra = parse_core "and (equalNat (addNat 4 5) 9) (and (equalNat (mulNat 6 7) 42) (and (equalNat (minNat 3 8) 3) (and (equalNat (maxNat 3 8) 8) (and (equalNat (expNat 2 5) 32) (and (equalNat (doubleNat 6) 12) (and (equalNat (pred 0) 0) (and (equalNat (pred 9) 8) (ltNat 3 4))))))))";

prove_print w4 nat_scalar_extra;
write_lean_term
  "ScalarNatExtraConformance" [] []
  "test_conformance_scalar_extra.nat.result.lean"
  nat_scalar_extra;

let int_scalar_extra = parse_core "and (intEq (intAdd (intNeg (natToInt 2)) (natToInt 5)) (natToInt 3)) (and (intEq (intSub (natToInt 2) (natToInt 5)) (intNeg (natToInt 3))) (and (intEq (intMul (intNeg (natToInt 3)) (natToInt 4)) (intNeg (natToInt 12))) (and (intLe (intNeg (natToInt 3)) (natToInt 2)) (and (intLt (intNeg (natToInt 3)) (natToInt 2)) (and (equalNat (intToNat (intNeg (natToInt 3))) 0) (equalNat (intToNat (natToInt 7)) 7))))))";

prove_print w4 int_scalar_extra;
write_lean_term
  "ScalarIntExtraConformance" [] []
  "test_conformance_scalar_extra.int.result.lean"
  int_scalar_extra;

let intmod_scalar_extra = parse_core "and (intEq (fromIntMod 5 (toIntMod 5 (natToInt 12))) (natToInt 2)) (and (intModEq 5 (intModSub 5 (toIntMod 5 (natToInt 1)) (toIntMod 5 (natToInt 3))) (toIntMod 5 (natToInt 3))) (intModEq 5 (intModMul 5 (toIntMod 5 (natToInt 3)) (toIntMod 5 (natToInt 4))) (toIntMod 5 (natToInt 2))))";

prove_print w4 intmod_scalar_extra;
write_lean_term
  "ScalarIntModExtraConformance" [] []
  "test_conformance_scalar_extra.intmod.result.lean"
  intmod_scalar_extra;

let rational_scalar_extra = parse_core "and (rationalLe (ratio (natToInt 1) (natToInt 2)) (ratio (natToInt 2) (natToInt 3))) (and (rationalLt (ratio (natToInt 1) (natToInt 2)) (ratio (natToInt 2) (natToInt 3))) (and (rationalEq (rationalAdd (ratio (natToInt 1) (natToInt 2)) (ratio (natToInt 1) (natToInt 3))) (ratio (natToInt 5) (natToInt 6))) (and (rationalEq (rationalSub (ratio (natToInt 1) (natToInt 2)) (ratio (natToInt 1) (natToInt 3))) (ratio (natToInt 1) (natToInt 6))) (and (rationalEq (rationalMul (ratio (natToInt 1) (natToInt 2)) (ratio (natToInt 1) (natToInt 3))) (ratio (natToInt 1) (natToInt 6))) (and (rationalEq (rationalNeg (ratio (natToInt 1) (natToInt 2))) (ratio (intNeg (natToInt 1)) (natToInt 2))) (and (rationalEq (rationalRecip (ratio (natToInt 2) (natToInt 3))) (ratio (natToInt 3) (natToInt 2))) (intEq (rationalFloor (ratio (natToInt 7) (natToInt 2))) (natToInt 3))))))))";

prove_print w4 rational_scalar_extra;
write_lean_term
  "ScalarRationalExtraConformance" [] []
  "test_conformance_scalar_extra.rational.result.lean"
  rational_scalar_extra;
