// Differential conformance checks for concrete SAWCore Boolean primitives.
//
// This pins the SAWCore Prelude Boolean surface that is partly auto-emitted
// (`not`, `and`, `or`) and partly routed through checked Lean facades (`xor`,
// `boolEq`). SAW proves the closed source fact with `w4`; Lean emission then
// has to elaborate the same fact.

let boolean_conformance = parse_core "and (not False) (and (and True True) (and (or False True) (and (xor True False) (and (boolEq True True) (not (boolEq True False))))))";

prove_print w4 boolean_conformance;
write_lean_term
  "BooleanConformance" [] []
  "test_conformance_boolean.result.lean"
  boolean_conformance;
