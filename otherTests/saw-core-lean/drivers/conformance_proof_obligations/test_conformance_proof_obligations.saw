// Conformance checks for proof-carrying emission surfaces.
//
// This fixture intentionally does not call `prove_print`: the source term uses
// SAWCore's `unsafeAssert`, whose whole point is to introduce an equality claim.
// The conformance property is that the Lean backend emits that claim as a
// visible local proof obligation, then feeds the checked evidence to `coerce`.

let unsafe_assert_coerce_obligation =
  parse_core "equalNat (coerce Nat Nat (unsafeAssert (sort 0) Nat Nat) 3) 3";

write_lean_term
  "UnsafeAssertCoerceObligation" [] []
  "test_conformance_proof_obligations.result.lean"
  unsafe_assert_coerce_obligation;
