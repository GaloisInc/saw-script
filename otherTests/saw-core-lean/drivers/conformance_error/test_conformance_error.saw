// Differential conformance checks for unreachable Cryptol `error` branches.
//
// Reachable errors are partial behavior and should be exposed as proof
// obligations or `Except.error` values, not silently erased. This fixture
// checks the safe, source-proved case: the error-producing branch is
// unreachable under SAW's semantics, and Lean emission must preserve the
// explicit error value in the unchosen branch without making the closed fact
// fail to elaborate.

let error_conformance = {{
  ((if True then (1 : [8]) else error "boom") == 1) &&
  ((if False then error "boom" else (2 : [8])) == 2)
}};

prove_print w4 error_conformance;
write_lean_term
  "ErrorConformance" [] []
  "test_conformance_error.result.lean"
  error_conformance;
