// Differential conformance checks for bitvector conversion primitives.
//
// `conformance_bitvector` covers arithmetic, comparisons, shifts, extensions,
// and bit-counting. This fixture adds the conversion surface.

let bitvector_conversion_conformance = parse_core "and (equalNat (bvToNat 8 0xff) 255) (and (intEq (bvToInt 8 0x7f) (natToInt 127)) (and (intEq (sbvToInt 8 0xff) (intNeg (natToInt 1))) (and (bvEq 8 (bvNat 8 257) 0x01) (and (bvEq 8 (intToBv 8 (intNeg (natToInt 1))) 0xff) (bvEq 8 (intToBv 8 (natToInt 257)) 0x01)))))";

prove_print w4 bitvector_conversion_conformance;
write_lean_term
  "BitvectorConversionConformance" [] []
  "test_conformance_bitvector_conversions.result.lean"
  bitvector_conversion_conformance;
