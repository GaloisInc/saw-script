// Differential conformance checks for SAWCore `bytesToString`.
//
// This covers the string primitive that Cryptol error-message plumbing uses
// after elaborating a literal string to bytes.

let string_bytes_conformance = parse_core "equalString (bytesToString 2 (gen 2 (Vec 8 Bool) (\\(i : Nat) -> ite (Vec 8 Bool) (equalNat i 0) 0x48 0x69))) \"Hi\"";

prove_print w4 string_bytes_conformance;
write_lean_term
  "StringBytesConformance" [] []
  "test_conformance_string_bytes.result.lean"
  string_bytes_conformance;
