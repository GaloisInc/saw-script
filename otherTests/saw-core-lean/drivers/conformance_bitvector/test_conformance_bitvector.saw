// Differential conformance checks for concrete, defined SAWCore bitvector
// semantics.
//
// Each property is checked twice:
//   1. `prove_print w4` checks the closed SAWCore property.
//   2. `write_lean_term` emits the same property for Lean elaboration, while
//      the paired proof fixture checks the corresponding Lean support-library
//      realizations directly.
//
// This catches SAW-vs-Lean semantic drift in support-library realizations.

// Division/remainder by zero is intentionally absent here. SAW's concrete and
// What4/RME paths currently treat those cases as undefined, so the Lean backend
// must eventually emit an explicit divisor-nonzero obligation instead of
// claiming a total value. This test only pins defined cases.
let bitvector_conformance = parse_core "and (bvEq 8 (bvAdd 8 0x0f 0x01) 0x10) (and (bvEq 8 (bvSub 8 0x00 0x01) 0xff) (and (bvEq 8 (bvMul 8 0x10 0x10) 0x00) (and (bvEq 8 (bvNeg 8 0x01) 0xff) (and (bvEq 8 (bvShl 8 0x81 1) 0x02) (and (bvEq 8 (bvShr 8 0x81 1) 0x40) (and (bvEq 8 (bvNot 8 0x0f) 0xf0) (and (bvEq 8 (bvAnd 8 0xf0 0xcc) 0xc0) (and (bvEq 8 (bvOr 8 0xf0 0x0f) 0xff) (and (bvEq 8 (bvXor 8 0xaa 0xff) 0x55) (and (bvult 8 0x01 0x02) (and (bvule 8 0x02 0x02) (and (bvugt 8 0x03 0x02) (and (bvuge 8 0x02 0x02) (and (bvslt 8 0xff 0x01) (and (bvsle 8 0xff 0xff) (and (bvsgt 8 0x01 0xff) (and (bvsge 8 0xff 0xff) (and (bvEq 8 (bvUExt 4 4 0xf) 0x0f) (and (bvEq 8 (bvSExt 4 3 0xf) 0xff) (and (bvEq 8 (bvPopcount 8 0xf0) 0x04) (and (bvEq 8 (bvCountLeadingZeros 8 0x0f) 0x04) (and (bvEq 8 (bvCountTrailingZeros 8 0xf0) 0x04) (and (bvEq 8 (bvUDiv 8 0x0d 0x03) 0x04) (and (bvEq 8 (bvURem 8 0x0d 0x03) 0x01) (and (bvEq 8 (bvSDiv 7 0xf9 0x02) 0xfd) (and (bvEq 8 (bvSRem 7 0xf9 0x02) 0xff) (and (bvEq 8 (bvSShr 7 0xf8 1) 0xfc) (and (bvEq 8 (bvLg2 8 0x00) 0x00) (and (bvEq 8 (bvLg2 8 0x01) 0x00) (and (bvEq 8 (bvLg2 8 0x03) 0x02) (and (bvEq 8 (bvLg2 8 0x04) 0x02) (bvEq 8 (bvLg2 8 0x05) 0x03))))))))))))))))))))))))))))))))";

prove_print w4 bitvector_conformance;
write_lean_term
  "BitvectorConformance" [] []
  "test_conformance_bitvector.result.lean"
  bitvector_conformance;
