// Obligation-emission coverage for SAWCore operations whose active SAW
// concrete/What4 semantics leave zero divisors undefined.
//
// This intentionally does not call `prove_print`: the point is not that these
// closed formulas are true in SAW, but that Lean emission does not silently
// totalize them. The generated Lean must elaborate only by exposing local
// nonzero proof obligations for each divisor/reciprocal argument.

let zero_divisor_obligations = parse_core "and (equalNat (divNat 1 0) 0) (and (equalNat (modNat 1 0) 0) (and (intEq (intDiv (natToInt 1) (natToInt 0)) (natToInt 0)) (and (intEq (intMod (natToInt 1) (natToInt 0)) (natToInt 0)) (and (bvEq 8 (bvUDiv 8 0x01 0x00) 0x00) (and (bvEq 8 (bvURem 8 0x01 0x00) 0x00) (and (bvEq 8 (bvSDiv 7 0x01 0x00) 0x00) (and (bvEq 8 (bvSRem 7 0x01 0x00) 0x00) (and (rationalEq (ratio (natToInt 1) (natToInt 0)) rationalZero) (rationalEq (rationalRecip rationalZero) rationalZero)))))))))";

write_lean_term
  "ZeroDivisorObligations" [] []
  "test_zero_divisor_obligations.result.lean"
  zero_divisor_obligations;

let zero_divmod_nat_obligation = parse_core "divModNat 1 0";

write_lean_term
  "ZeroDivModNatObligation" [] []
  "test_zero_divisor_obligations.divmod_nat.result.lean"
  zero_divmod_nat_obligation;
