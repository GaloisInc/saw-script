// Differential conformance checks for concrete SAWCore stream primitives.
//
// SAW proves concrete `Stream#rec`, `MkStream`, and `streamScanl` facts with
// `w4`. The emitted Lean term must elaborate with the explicit `MkStream`
// totality obligation. The paired Lean proof pins the corresponding
// support-library stream realizations directly.

let stream_conformance = parse_core "and (Stream#rec Nat (\\(_ : Stream Nat) -> Bool) (\\(xs : Nat -> Nat) -> equalNat (xs 5) 5) (MkStream Nat (\\(i : Nat) -> i))) (equalNat (Stream#rec Nat (\\(_ : Stream Nat) -> Nat) (\\(xs : Nat -> Nat) -> xs 3) (streamScanl Nat Nat addNat 0 (MkStream Nat (\\(i : Nat) -> 1)))) 3)";

prove_print w4 stream_conformance;
write_lean_term
  "StreamConformance" [] []
  "test_conformance_stream.result.lean"
  stream_conformance;
