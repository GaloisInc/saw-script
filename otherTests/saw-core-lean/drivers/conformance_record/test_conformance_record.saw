// Differential conformance checks for concrete SAWCore/Cryptol record
// construction, projection, nesting, and update semantics.
//
// The record-only driver coverage already pins emitted syntax. This fixture
// adds the semantic half: SAW proves the source properties with `w4`, while the
// paired Lean proof pins the `RecordType` support-library representation.

let p = {{ {x = 1, y = 2} : {x : [8], y : [8]} }};
let nested = {{ {inner = p, z = 3} : {inner : {x : [8], y : [8]}, z : [8]} }};

let record_conformance = {{
  (p.x == 1) &&
  (p.y == 2) &&
  (nested.inner.x == 1) &&
  (({ p | x = 3 }).x == 3) &&
  (({ p | y -> y + 5 }).y == 7)
}};

prove_print w4 record_conformance;
write_lean_term
  "RecordConformance" [] []
  "test_conformance_record.result.lean"
  record_conformance;
