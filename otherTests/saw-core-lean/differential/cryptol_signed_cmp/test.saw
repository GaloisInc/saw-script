// TRUE differential litmus for Cryptol.sawcore signed comparison dictionaries.

let observed =
  parse_core
    "and (ecSLt (Vec 8 Bool) (PSignedCmpWord 8) 0xff 0x01) (not (ecSLt (Vec 8 Bool) (PSignedCmpWord 8) 0x01 0xff))";

print (str_concat "SAW_OBSERVED: " (show (eval_bool observed)));

write_lean_term
  "Observed" [] []
  "observed.lean"
  observed;
