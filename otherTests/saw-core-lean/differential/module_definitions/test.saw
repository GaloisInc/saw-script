// TRUE differential litmus for loaded SAWCore module definitions and names.

enable_experimental;

load_sawcore_from_file "LocalDefs.sawcore";

let observed = parse_core_mod "LocalDefs" "observed";

print (str_concat "SAW_OBSERVED: " (show (eval_bool observed)));

write_lean_term
  "Observed" [] []
  "observed.lean"
  observed;
