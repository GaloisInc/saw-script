// TRUE differential litmus for Cryptol.sawcore `ecExp`.

let observed =
  parse_core
    "intEq (ecExp Integer Integer PRingInteger PIntegralInteger (natToInt 2) (natToInt 3)) (natToInt 8)";

print (str_concat "SAW_OBSERVED: " (show (eval_bool observed)));

write_lean_term
  "Observed" [] []
  "observed.lean"
  observed;
