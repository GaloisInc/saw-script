// TRUE differential litmus for Cryptol.sawcore `ecAt` with an integral index.

let observed =
  parse_core
    "and (equalNat (ecAt (TCNum 4) Nat Integer PIntegralInteger (gen 4 Nat (\\(i : Nat) -> addNat i 10)) (natToInt 2)) 12) (equalNat (ecAt (TCNum 4) Nat Integer PIntegralInteger (gen 4 Nat (\\(i : Nat) -> addNat i 10)) (intNeg (natToInt 1))) 10)";

print (str_concat "SAW_OBSERVED: " (show (eval_bool observed)));

write_lean_term
  "Observed" [] []
  "observed.lean"
  observed;
