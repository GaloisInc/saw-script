// TRUE differential litmus for direct Cryptol.sawcore signed word division
// and modulus entry points.

let observed =
  parse_core
    "and (bvEq 8 (ecSDiv (TCNum 8) 0xf9 0x02) 0xfd) (bvEq 8 (ecSMod (TCNum 8) 0xf9 0x02) 0xff)";

print (str_concat "SAW_OBSERVED: " (show (eval_bool observed)));

write_lean_term
  "Observed" [] []
  "observed.lean"
  observed;
