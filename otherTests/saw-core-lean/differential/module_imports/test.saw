// TRUE differential litmus for SAWCore module imports and qualified names.

enable_experimental;

load_sawcore_from_file "A.sawcore";
load_sawcore_from_file "B.sawcore";

let observed = parse_core_mod "B" "observed";

print (str_concat "SAW_OBSERVED: " (show (eval_bool observed)));

write_lean_term
  "Observed" [] []
  "observed.lean"
  observed;
