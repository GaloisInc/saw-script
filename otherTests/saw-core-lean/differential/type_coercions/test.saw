// TRUE differential litmus for safe Prelude type coercions with Refl evidence.

let observed =
  parse_core
    "and (equalNat (coerce Nat Nat (Refl (sort 0) Nat) 3) 3) (equalNat (rcoerce Nat Nat (Refl (sort 0) Nat) 4) 4)";

print (str_concat "SAW_OBSERVED: " (show (eval_bool observed)));

write_lean_term
  "Observed" [] []
  "observed.lean"
  observed;
