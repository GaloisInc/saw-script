// TRUE differential litmus for bitvector conversion primitives.
//
// SIGN-CROSSING CASES ARE LOAD-BEARING (2026-07-23 soundness fix):
// bvToInt is UNSIGNED and sbvToInt is SIGNED (Prelude.sawcore
// 2113/2116), and the two must be pinned on the SAME sign-bit-set
// input (0xff -> 255 vs -1) so a realization that conflates them —
// the audit-found defect: both were BitVec.toInt — can never pass
// this row again. The original row only checked bvToInt at 0x7f,
// which never crosses the sign bit.

let observed =
  parse_core "and (equalNat (bvToNat 8 0xff) 255) (and (intEq (bvToInt 8 0x7f) (natToInt 127)) (and (intEq (bvToInt 8 0xff) (natToInt 255)) (and (intEq (sbvToInt 8 0xff) (intNeg (natToInt 1))) (and (bvEq 8 (bvNat 8 257) 0x01) (and (bvEq 8 (intToBv 8 (intNeg (natToInt 1))) 0xff) (bvEq 8 (intToBv 8 (natToInt 257)) 0x01))))))";

print (str_concat "SAW_OBSERVED: " (show (eval_bool observed)));

write_lean_term
  "Observed" [] []
  "observed.lean"
  observed;
