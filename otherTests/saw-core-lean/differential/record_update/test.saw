// TRUE differential litmus for Cryptol record update and nested projection.

let p = {{ {x = 1, y = 2} : {x : [8], y : [8]} }};
let nested = {{ {inner = p, z = 3} : {inner : {x : [8], y : [8]}, z : [8]} }};

let observed = {{
  (nested.inner.x == 1) &&
  (({ p | x = 3 }).x == 3) &&
  (({ p | y -> y + 5 }).y == 7)
}};

print (str_concat "SAW_OBSERVED: " (show (eval_bool observed)));

write_lean_term
  "Observed" [] []
  "observed.lean"
  observed;
