// TRUE differential litmus for bitvector ordering, extension, and bit counts.

let observed =
  parse_core "and (bvult 8 0x01 0x02) (and (bvule 8 0x02 0x02) (and (bvugt 8 0x03 0x02) (and (bvuge 8 0x02 0x02) (and (bvslt 8 0xff 0x01) (and (bvsle 8 0xff 0xff) (and (bvsgt 8 0x01 0xff) (and (bvsge 8 0xff 0xff) (and (bvEq 8 (bvUExt 4 4 0xf) 0x0f) (and (bvEq 8 (bvSExt 4 3 0xf) 0xff) (and (bvEq 8 (bvPopcount 8 0xf0) 0x04) (and (bvEq 8 (bvCountLeadingZeros 8 0x0f) 0x04) (and (bvEq 8 (bvCountTrailingZeros 8 0xf0) 0x04) (and (bvEq 8 (bvLg2 8 0x00) 0x00) (and (bvEq 8 (bvLg2 8 0x03) 0x02) (bvEq 8 (bvLg2 8 0x05) 0x03)))))))))))))))";

print (str_concat "SAW_OBSERVED: " (show (eval_bool observed)));

write_lean_term
  "Observed" [] []
  "observed.lean"
  observed;
