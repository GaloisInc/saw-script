// TRUE differential litmus for Cryptol.sawcore `Num`, `TCNum`, and `TCInf`.

let observed =
  parse_core
    "and (tcFin (TCNum 3)) (and (not (tcFin TCInf)) (equalNat (getFinNat (TCNum 5)) 5))";

print (str_concat "SAW_OBSERVED: " (show (eval_bool observed)));

write_lean_term
  "Observed" [] []
  "observed.lean"
  observed;
