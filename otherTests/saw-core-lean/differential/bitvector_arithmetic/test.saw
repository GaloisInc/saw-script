// TRUE differential litmus for defined bitvector arithmetic.
//
// Zero-divisor cases are intentionally not here; those need explicit
// proof-obligation rows rather than total value tests.

let observed =
  parse_core "and (bvEq 8 (bvAdd 8 0x0f 0x01) 0x10) (and (bvEq 8 (bvSub 8 0x00 0x01) 0xff) (and (bvEq 8 (bvMul 8 0x10 0x10) 0x00) (and (bvEq 8 (bvNeg 8 0x01) 0xff) (and (bvEq 8 (bvUDiv 8 0x0d 0x03) 0x04) (and (bvEq 8 (bvURem 8 0x0d 0x03) 0x01) (and (bvEq 8 (bvSDiv 7 0xf9 0x02) 0xfd) (bvEq 8 (bvSRem 7 0xf9 0x02) 0xff)))))))";

print (str_concat "SAW_OBSERVED: " (show (eval_bool observed)));

write_lean_term
  "Observed" [] []
  "observed.lean"
  observed;
