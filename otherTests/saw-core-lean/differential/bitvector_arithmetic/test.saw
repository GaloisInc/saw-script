// TRUE differential litmus for total bitvector arithmetic.
//
// Division/remainder cases are intentionally not here. They are partial
// operations in the SAW-Lean backend and need checked nonzero obligations
// even when this concrete divisor is nonzero; see bitvector_division.

let observed =
  parse_core "and (bvEq 8 (bvAdd 8 0x0f 0x01) 0x10) (and (bvEq 8 (bvSub 8 0x00 0x01) 0xff) (and (bvEq 8 (bvMul 8 0x10 0x10) 0x00) (bvEq 8 (bvNeg 8 0x01) 0xff)))";

print (str_concat "SAW_OBSERVED: " (show (eval_bool observed)));

write_lean_term
  "Observed" [] []
  "observed.lean"
  observed;
