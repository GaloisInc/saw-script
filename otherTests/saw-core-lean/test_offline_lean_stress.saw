// Stress-test plan (doc/2026-05-03_stress-test-plan.md) — offline_lean
// drivers for E1..E10. Each prove_print emits a `*.prove0.lean`
// file with a Cryptol property as `goal : Prop` and a sorry
// placeholder; the corresponding intTests/test_lean_E<N>_*_proof/
// directory carries the discharge.
//
// SAW's SMT prover will fail/succeed per usual on these — the
// prove_print result is not what we test. What we test is:
//   (1) SAW emits the .lean file with the expected shape (pinned
//       via *.prove0.lean.good).
//   (2) The Lean discharge in intTests/... closes cleanly.

// E1 — bvAdd commutativity over [8]. Baseline one-liner via
// bvAdd_comm. Tier 1.
prove_print (offline_lean "test_offline_lean_stress.E1")
  {{ \(x : [8]) (y : [8]) -> x + y == y + x }};

// E2 — iteDep reflexivity. `(if b then x else y) == (if b then x
// else y)` — same term on both sides. Exercises the SAW ite
// wrapper and bvEq_refl. Tier 1.
prove_print (offline_lean "test_offline_lean_stress.E2")
  {{ \(b : Bit) (x : [8]) (y : [8]) ->
       (if b then x else y) == (if b then x else y) }};

// E3 — Point record-field commutativity. Mirrors the
// PointExercise.cry use case, but stated inline here so the
// whole stress sequence lives in one driver. Two-field record
// with bvAdd per field; commutativity follows from bvAdd_comm
// per field. Exercises RecordType.rec reduction + nested records.
// Tier 2.
let {{
  type Point = { x : [32], y : [32] }
  point_add : Point -> Point -> Point
  point_add p1 p2 = { x = p1.x + p2.x, y = p1.y + p2.y }
}};
prove_print (offline_lean "test_offline_lean_stress.E3")
  {{ \(p1 : Point) (p2 : Point) -> point_add p1 p2 == point_add p2 p1 }};

// E4 — sequence-level bv identity: map of bvAdd-with-zero is the
// identity. Exercises Cryptol `map`, @/atWithDefault indexing,
// bvAdd_id_r per element, and sequence equality. Tier 2.
prove_print (offline_lean "test_offline_lean_stress.E4")
  {{ \(xs : [4][32]) -> map (\x -> x + 0) xs == xs }};

// E5 — littleendian round-trip. Salsa20 formulation:
//   littleendian b         = join (reverse b)
//   littleendian_inverse b = reverse (split b)
// Property: \(b : [4][8]) -> littleendian_inverse (littleendian b) == b.
// Pure algebraic identity over join/split/reverse round-trip on
// a [4][8] byte-vector. Tier 3.
let {{
  littleendian : [4][8] -> [32]
  littleendian b = join (reverse b)

  littleendian_inverse : [32] -> [4][8]
  littleendian_inverse b = reverse (split b)
}};
prove_print (offline_lean "test_offline_lean_stress.E5")
  {{ \(b : [4][8]) -> littleendian_inverse (littleendian b) == b }};
